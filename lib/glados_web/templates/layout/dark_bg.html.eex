<!DOCTYPE html>
<html lang="en">
<%= render "head.html", conn: @conn %>

<body class="bg-payne w-full min-h-screen relative">
  <%= unless @dismiss_cookies do %>
  <div
    class="js-cookie_notice w-full bg-aqua text-xs text-center py-1 shadow-lg flex flex-row items-center justify-between">
    <div></div>
    <div>Glados bruker cookies så hun kan huske hvem du er mens du er logget inn.</div>
    <div class="float-right text-base px-4 py-2 js-close_cookie_notice cursor-pointer">x</div>
  </div>
  <% end %>
  <main role="main" class="pt-8 lg:pt-24 pb-20">
    <div class="max-w-2xl m-auto shadow-2xl">
      <%= render(GladosWeb.CommonView, "guest_bar.html", conn: @conn,
        current_path: :login) %>
      <div class="rounded-b-md pb-4 bg-white w-11/12 md:w-full mx-auto">
        <%= render @view_module, @view_template, assigns %>
      </div>
    </div>
    <br />
    <div class="w-11/12 md:w-full mx-auto"><%= render "alert.html", conn: @conn %></div>
  </main>
  <div class="text-white">
    <%= render(GladosWeb.CommonView, "footer.html") %>
  </div>
</body>

</html>