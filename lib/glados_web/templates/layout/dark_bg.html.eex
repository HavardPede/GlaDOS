<!DOCTYPE html>
<html lang="en">
<%= render "head.html", conn: @conn %>

<body class="bg-payne w-full min-h-screen relative">
  <main role="main" class="pt-8 lg:pt-24 pb-20">
    <div class="max-w-2xl m-auto shadow-2xl">
      <%= render(GladosWeb.CommonView, "guest_bar.html", conn: @conn,
        current_path: :login) %> <%= render @view_module, @view_template,
        assigns %>
    </div>
    <br />
    <%= render "alert.html", conn: @conn %>
  </main>
  <div class="text-white">
    <%= render(GladosWeb.CommonView, "footer.html") %>
  </div>
</body>

</html>