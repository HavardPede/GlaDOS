<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Glados · ESLG crew portal</title>
    <link rel="stylesheet" href="<%= Routes.static_path(@conn, "/css/app.css") %>"/>
  </head>

  <link rel="stylesheet" href="//fonts.googleapis.com/css?family=Roboto:300,300italic,700,700italic">
  <link rel="stylesheet" href="//cdn.rawgit.com/necolas/normalize.css/master/normalize.css">
  <script type="text/javascript" src="<%= Routes.static_path(@conn, "/js/app.js") %>"></script>

  <body class="login_bg ">
    <main role="main">
      <%= render @view_module, @view_template, assigns %>
      <br>
      <div class="login_alert_container">
        <p class="alert bg-blue-400 text-blue-900 p-3 shadow-xl rounded relative max-w-2xl m-auto" role="alert"><%= get_flash(@conn, :info) %></p>
        <p class="alert bg-red-400 text-red-900 p-3  shadow-xl rounded relative max-w-2xl m-auto" role="alert"><%= get_flash(@conn, :error) %></p>
      </div>
    </main>
  </body>
</html>
